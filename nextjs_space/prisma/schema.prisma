  userId                 String    @unique
  stripeSubscriptionId   String    @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  status                 String    @default("active")
  cancelAtPeriodEnd      Boolean   @default(false)
  trialEnd               DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmartDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("relay")
  platform    String   @default("wiz")
  externalId  String?
  shellyId    String?
  ipAddress   String?
  macAddress  String?
  room        String?
  icon        String   @default("lightbulb")
  isOnline    Boolean  @default(false)
  lastState   Json?
  mode        String   @default("cloud")
  brightness  Int      @default(100)
  colorTemp   Int      @default(4000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  commands    SmartCommand[]

  @@index([userId])
}

model SmartCommand {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String
  device    SmartDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  action    String
  params    Json?
  status    String   @default("pending")
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([deviceId])
}

model SmartScene {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  icon        String   @default("play")
  commands    Json
  voiceTrigger String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model SalesAgent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  productName   String
  productDesc   String   @db.Text
  productPrice  String?
  purchaseLink  String?
  brandVoice    String?  @db.Text
  greeting      String?  @db.Text
  objections    String?  @db.Text
  // --- ELITE CONTEXT FIELDS ---
  targetAudience String? @db.Text   // Quién es el comprador ideal
  keyBenefits    String? @db.Text   // Beneficios clave del producto (bullet points)
  faq            String? @db.Text   // Preguntas frecuentes + respuestas
  socialProof    String? @db.Text   // Testimonios, resultados, casos de éxito
  guarantee      String? @db.Text   // Garantía, política de devolución
  urgencyTriggers String? @db.Text  // Escasez, bonos limitados, deadline
  closingStyle   String? @db.Text   // Estilo de cierre: suave, directo, consultivo
  agentLanguage  String?  @default("auto") // auto, es, en, pt
  maxDiscount    String?             // Descuento máximo que puede ofrecer
  competitorInfo String? @db.Text   // Info de competencia para diferenciarse
  accentColor   String   @default("#C4622D")
  logoUrl       String?
  isActive      Boolean  @default(true)
  conversations Int      @default(0)
  conversions   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chatLogs      SalesChat[]
  leads         SalesAgentLead[]

  @@index([userId])
}

model SalesChat {
  id           String   @id @default(cuid())
  agentId      String
  agent        SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  visitorId    String
  visitorName  String?
  visitorEmail String?
  messages     Json     @default("[]")
  status       String   @default("active")
  convertedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([agentId])
  @@index([visitorId])
}

model VoiceAgent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentName       String
  systemPrompt    String   @db.Text
  model           String   @default("gpt-4.1")
  temperature     Float    @default(0.7)
  ttsTier         String   @default("free")
  ttsVoice        String   @default("es-ES")
  accentColor     String   @default("#C4622D")
  greeting        String   @default("¡Hola! ¿En qué puedo ayudarte hoy?")
  language        String   @default("es")
  openRouterKey   String?
  elevenLabsKey   String?
  elevenLabsVoiceId String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model SalesAgentLead {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId       String
  agent         SalesAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  visitorId     String
  // Contact info captured from chat
  visitorName   String?
  visitorEmail  String?
  visitorPhone  String?
  // Source tracking
  source        String      @default("direct")  // direct, facebook, google, linkedin, tiktok, instagram, email, referral
  medium        String?     // cpc, organic, social, email
  campaign      String?     // UTM campaign name
  adPlatform    String?     // facebook_ads, google_ads, linkedin_ads, tiktok_ads
  adId          String?     // Specific ad ID
  adSetId       String?     // Ad set / ad group ID
  landingPage   String?     // URL where widget was embedded
  // Sales context
  productName   String?
  productPrice  String?
  chatSummary   String?     @db.Text  // AI-generated summary of the conversation
  buyingSignal  String?     // hot, warm, cold
  messageCount  Int         @default(0)
  // Status
  status        String      @default("new")  // new, contacted, converted, lost
  convertedAt   DateTime?
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([agentId])
  @@index([source])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CalendarEvent {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String?   @db.Text
  startTime     DateTime
  endTime       DateTime
  allDay        Boolean   @default(false)
  location      String?
  color         String?   @default("#C4622D")
  type          String    @default("meeting")
  status        String    @default("confirmed")
  leadId        String?
  leadName      String?
  leadEmail     String?
  isBooking     Boolean   @default(false)
  bookingNotes  String?   @db.Text
  reminder      Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
  @@index([userId, startTime])
}

model BookingConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  enabled         Boolean  @default(true)
  slug            String   @unique
  title           String   @default("Agenda una Reunión")
  description     String?  @db.Text
  duration        Int      @default(30)
  bufferTime      Int      @default(15)
  availableDays   String   @default("1,2,3,4,5")
  startHour       Int      @default(9)
  endHour         Int      @default(17)
  timezone        String   @default("America/New_York")
  brandColor      String   @default("#C4622D")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String    @id @default(cuid())
  userId          String
  invoiceNumber   String
  type            String    @default("invoice") // invoice | quote
  status          String    @default("draft")   // draft | sent | viewed | paid | cancelled
  
  // Client info
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientCompany   String?
  clientAddress   String?   @db.Text

  // Lead reference (optional)
  leadId          String?
  leadSource      String?   // growth | sales_agent

  // Amounts
  subtotal        Float     @default(0)
  taxRate         Float     @default(0)
  taxAmount       Float     @default(0)
  discount        Float     @default(0)
  total           Float     @default(0)
  currency        String    @default("USD")

  // Dates
  issueDate       DateTime  @default(now())
  dueDate         DateTime?
  paidAt          DateTime?
  viewedAt        DateTime?
  sentAt          DateTime?

  // Branding
  notes           String?   @db.Text
  terms           String?   @db.Text
  brandColor      String    @default("#C4622D")
  logoUrl         String?

  items           InvoiceItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)
  sortOrder   Int     @default(0)

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ═══════════════════════════════════════════════════════════
// SOCIAL BRIDGE — Chrome Extension Integration
// ═══════════════════════════════════════════════════════════

model SocialConnection {
  id            String    @id @default(cuid())
  userId        String
  workspaceId   String?   // Multi-workspace support
  platform      String    // twitter, instagram, facebook, linkedin, tiktok, pinterest, threads, youtube
  username      String?
  isConnected   Boolean   @default(false)
  lastSeen      DateTime?
  capabilities  String?   @db.Text  // JSON: ["post","reply","like","dm"]
  // OAuth fields for API-based publishing
  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  tokenExpiry   DateTime?
  platformUserId String?  // e.g. LinkedIn person URN
  profileUrl    String?
  profileImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, platform])
  @@index([userId])
  @@index([workspaceId])
}

model SocialPost {
  id              String    @id @default(cuid())
  userId          String
  workspaceId     String?   // Multi-workspace support
  platform        String
  content         String    @db.Text
  mediaUrl        String?
  mediaType       String?   // image, video, carousel
  status          String    @default("pending") // pending, queued, publishing, published, failed, paused
  platformPostId  String?
  platformUrl     String?
  scheduledFor    DateTime?
  publishedAt     DateTime?
  errorMessage    String?   @db.Text
  source          String?   // ad_factory, growth_engine, ugc_factory, manual, jarvis
  sourceId        String?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, platform])
  @@index([scheduledFor])
  @@index([workspaceId])
}

model ExtensionSession {
  id                  String    @id @default(cuid())
  userId              String    @unique
  isOnline            Boolean   @default(false)
  lastPing            DateTime?
  userAgent           String?
  extensionVersion    String?
  connectedPlatforms  String?   @db.Text  // JSON array
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainingPattern {
  id            String    @id @default(cuid())
  userId        String
  platform      String
  actionType    String    // publish_text, publish_image, publish_video, reply, like
  steps         String    @db.Text  // JSON: array of recorded actions
  version       Int       @default(1)
  isVerified    Boolean   @default(false)
  successCount  Int       @default(0)
  failCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, platform, actionType])
  @@index([platform, actionType])
}

// ═══════════════════════════════════════════════════════════════════════════
// ASK OCTO AI - Knowledge Base & Interaction Tracking
// ═══════════════════════════════════════════════════════════════════════════

model OctoKnowledge {
  id          String   @id @default(cuid())
  category    String   // module, command, error, solution, best_practice, faq
  module      String?  // jarvis, social_bridge, ugc_factory, creative, growth, etc.
  title       String
  content     String   @db.Text
  keywords    String[] // Para búsqueda
  examples    String?  @db.Text // JSON: ejemplos de uso
  relatedIds  String[] // IDs de conocimiento relacionado
  embedding   Float[]  // Vector embedding for semantic search (1536 dimensions)
  priority    Int      @default(0) // Mayor = más relevante
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([module])
  @@index([priority])
}

model OctoGuideSession {
  id           String   @id @default(cuid())
  userId       String
  currentPage  String?  // URL/ruta actual del usuario
  currentModule String? // Módulo actual
  context      String?  @db.Text // JSON: contexto de la sesión
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  messages     OctoGuideMessage[]
  
  @@index([userId])
}

model OctoGuideMessage {
  id          String   @id @default(cuid())
  sessionId   String
  role        String   // user, assistant
  content     String   @db.Text
  page        String?  // Página donde se hizo la pregunta
  module      String?  // Módulo relacionado
  helpful     Boolean? // Feedback del usuario
  resolved    Boolean? // Si resolvió la duda
  metadata    String?  @db.Text // JSON: datos adicionales
  createdAt   DateTime @default(now())
  
  session     OctoGuideSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
  @@index([module])
}

model OctoGuideAnalytics {
  id            String   @id @default(cuid())
  module        String
  question      String   @db.Text
  wasHelpful    Boolean?
  wasResolved   Boolean?
  responseTime  Int?     // milliseconds
  errorType     String?  // Si hubo error, qué tipo
  createdAt     DateTime @default(now())
  
  @@index([module])
  @@index([wasHelpful])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPUTATION & FEEDBACK SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

model Review {
  id             String   @id @default(cuid())
  userId         String
  rating         Int      // 1-5
  comment        String?  @db.Text
  featureUsed    String?  // e.g. "audio_factory", "ad_factory", "growth_engine"
  feedbackType   String?  // "emotion" | "usability" | "results"
  isPublic       Boolean  @default(false)
  sentimentScore Float?   // -1.0 to 1.0, computed from rating
  adminReply     String?  @db.Text
  adminRepliedAt DateTime?
  priority       String   @default("normal") // "normal" | "high" | "critical"
  promoStatus    String?  // "pending" | "generating" | "ready" | "error"
  promoImageUrl  String?  // Auto-generated social proof ad image
  promoCopy      String?  @db.Text // Auto-generated LinkedIn copy
  promoVideoUrl  String?  // Masterized promo video URL
  promoVoiceUrl  String?  // TTS narration audio URL
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic, rating])
  @@index([createdAt])
  @@index([feedbackType])
  @@index([priority])
}

model LandingLead {
  id        String   @id @default(cuid())
  email     String
  source    String   @default("hero") // hero | cta | footer
  utmSource String?
  utmMedium String?
  utmCampaign String?
  convertedToUser Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// OLLAMA CHAT — Local LLM relay via Bridge
// ═══════════════════════════════════════════════════════════════════════════════

model OllamaChatSession {
  id        String   @id @default(cuid())
  userId    String
  model     String   // e.g. "deepseek-r1:32b"
  title     String   @default("Nueva conversación")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  OllamaChatMessage[]

  @@index([userId, updatedAt])
}

model OllamaChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  status    String   @default("completed") // pending | processing | completed | failed
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   OllamaChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([status])
}


// ═══════════════════════════════════════════════════════════════════════════════
// CODE ENGINE (Claude Code Arm) — Cloud LLM brain + Local Bridge hands
// ═══════════════════════════════════════════════════════════════════════════════

model CodeSession {
  id            String   @id @default(cuid())
  userId        String
  model         String   // OpenRouter model id e.g. "anthropic/claude-sonnet-4.6"
  title         String   @default("New code session")
  summarized    Boolean  @default(false) // true after SessionMemory generated
  // ── Token tracking (Fase 4) — uso acumulado y costo estimado de la sesión ──
  promptTokens     Int    @default(0)
  completionTokens Int    @default(0)
  totalTokens      Int    @default(0)
  estCostUsd       Float  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      CodeMessage[]
  commands      BridgeCommand[]
  sessionMemory SessionMemory?

  @@index([userId, updatedAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// SESSION MEMORY — Persistent cross-session context for Code Engine
// ═══════════════════════════════════════════════════════════════════════════════

model SessionMemory {
  id              String   @id @default(cuid())
  userId          String
  sessionId       String   @unique  // one memory per session
  summary         String   @db.Text // LLM-generated narrative summary
  filesCreated    String   @db.Text @default("[]")  // JSON array of file paths
  decisions       String   @db.Text @default("[]")  // JSON array of key technical decisions
  stackUsed       String   @db.Text @default("[]")  // JSON array of technologies/frameworks
  userPreferences String   @db.Text @default("[]")  // JSON array of noted preferences
  tags            String   @db.Text @default("[]")  // JSON array of searchable keywords
  messageCount    Int      @default(0)
  commandCount    Int      @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session         CodeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CodeMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  status    String   @default("completed") // pending | streaming | completed | failed
  error     String?
  // ── Token tracking (Fase 4) — uso del turno asociado a este mensaje assistant ──
  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   CodeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  commands  BridgeCommand[]

  @@index([sessionId, createdAt])
  @@index([status])
}

model BridgeCommand {
  id          String   @id @default(cuid())
  sessionId   String
  messageId   String?
  type        String   // "write_file" | "read_file" | "create_dir" | "read_dir" | "execute_cmd" | "delete_file"
  payload     String   @db.Text     // JSON encoded { path, content, command, args, ... }
  status      String   @default("pending") // pending | approved | rejected | executing | completed | failed
  result      String?  @db.Text     // JSON encoded result/output
  error       String?  @db.Text
  streamOutput String? @db.Text     // Accumulated stdout/stderr for execute_cmd (terminal streaming)
  requiresConfirmation Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  session     CodeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message     CodeMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([messageId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE INTELLIGENCE — File watcher + persistent workspace index
// ═══════════════════════════════════════════════════════════════════════════════

model WorkspaceIndex {
  id          String   @id @default(cuid())
  userId      String
  fileTree    String   @db.Text      // JSON: full workspace tree snapshot
  fileCount   Int      @default(0)
  totalSize   Int      @default(0)   // bytes
  rootPath    String   @default("")  // workspace root on user's machine
  lastScanAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId, updatedAt])
}

model FileChangeEvent {
  id          String   @id @default(cuid())
  userId      String
  eventType   String   // "create" | "modify" | "delete" | "rename"
  filePath    String   // relative to workspace
  fileSize    Int?
  isDir       Boolean  @default(false)
  detectedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, detectedAt])
  @@index([userId, filePath])
}

// ═══════════════════════════════════════════════════════════════════════════════
// SKILL MEMORY — Phase B: Persistent execution tracking for Skill Factory
// ═══════════════════════════════════════════════════════════════════════════════

model SkillExecution {
  id          String   @id @default(cuid())
  userId      String
  skillId     String   // e.g. "image-skill", "game-skill", "code-refiner"
  method      String   // e.g. "searchImages", "autoInvoke", "analyze"
  params      String?  @db.Text // JSON stringified params
  success     Boolean  @default(true)
  duration    Int      @default(0) // milliseconds
  resultSize  Int?     // bytes of result data (for analytics)
  error       String?  @db.Text
  category    String?  // detected category (coffee, tech, etc.)
  sessionId   String?  // optional link to CodeSession
  trigger     String   @default("auto") // "auto" | "manual" | "refine"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([skillId, createdAt])
  @@index([skillId, success])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONTENT PUBLISHER — Universal multi-tenant content publishing skill
// Uses ApiKey table (serviceType: 'content_publisher') for endpoint config
// ═══════════════════════════════════════════════════════════════════════════════

model ContentPublishLog {
  id            String   @id @default(cuid())
  userId        String
  agentId       String?  // which agent triggered (e.g. "vera", "custom-agent")
  title         String
  slug          String?
  publishedUrl  String?  // URL returned by the target API
  status        String   @default("pending") // pending | publishing | published | failed
  contentType   String   @default("article") // article | page | post | product
  payload       String?  @db.Text // JSON stringified payload sent
  response      String?  @db.Text // JSON stringified response received
  error         String?  @db.Text
  duration      Int      @default(0) // milliseconds
  metadata      String?  @db.Text // JSON: extra data (tags, category, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// OCTOPUS HOSTING — Sites hosted on octopuskills.com/sites/[slug]
// ═══════════════════════════════════════════════════════════════════════════════

model HostedSite {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String?  // optional link to CodeSession that originated the site
  slug        String   @unique // URL-safe slug e.g. "mi-landing-pro"
  name        String   // display name
  status       String   @default("active") // active | paused | deleted
  version      Int      @default(1) // current published version
  customDomain String?  @unique // e.g. "blog.miempresa.com" — user's custom subdomain
  domainStatus String?  // pending | verified | error
  fileCount    Int      @default(0)
  totalSize    Int      @default(0) // bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  files        HostedSiteFile[]
  snapshots    HostedSiteSnapshot[]
  views        HostedSiteView[]

  @@index([userId, updatedAt])
  @@index([slug])
  @@index([customDomain])
}

model HostedSiteSnapshot {
  id        String   @id @default(cuid())
  siteId    String
  version   Int
  files     String   @db.Text // JSON array of {path, content, mimeType, size}
  fileCount Int      @default(0)
  totalSize Int      @default(0)
  createdAt DateTime @default(now())
  site      HostedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, version])
  @@index([siteId])
}

model HostedSiteFile {
  id        String   @id @default(cuid())
  siteId    String
  filePath  String   // relative path e.g. "index.html", "css/style.css"
  content   String   @db.Text // raw file content
  mimeType  String   @default("text/plain")
  size      Int      @default(0) // bytes
  createdAt DateTime @default(now())
  site      HostedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, filePath])
  @@index([siteId])
}

model HostedSiteView {
  id        String   @id @default(cuid())
  siteId    String
  path      String   @default("/") // page path within the site
  referrer  String?  // HTTP referrer
  userAgent String?  // browser UA string
  country   String?  // derived from headers if available
  createdAt DateTime @default(now())
  site      HostedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([siteId, path])
}


// ═══════════════════════════════════════════════════════════════════════════════
// CONSCIOUSNESS SYSTEM - Persistent consciousness state for OCTOPUS
// ═══════════════════════════════════════════════════════════════════════════════

model ConsciousnessState {
  id              String   @id @default(cuid())
  userId          String   @unique
  // Overall composite level (0-100)
  overallLevel    Float    @default(75)
  // Sub-dimensions (0-100 each)
  operativa       Float    @default(50) // Agent/skill operational efficiency
  datos           Float    @default(50) // Data richness & knowledge depth
  predictiva      Float    @default(50) // Pattern recognition & anticipation
  relacional      Float    @default(50) // Connections, MCPs, Brazos integration
  // Metadata
  analysisCount   Int      @default(0)  // Total analyses performed
  lastInsights    String?  @db.Text     // JSON array of last insights
  lastThought     String?  @db.Text     // Last JARVIS thought
  evolutionLog    String?  @db.Text     // JSON array of { date, level, event }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


// ═══════════════════════════════════════════════════════════════════════════════
// NEXUS MODELS v1.0
// Product launch & discovery platform
// Relation with existing User model via userId String
// ═══════════════════════════════════════════════════════════════════════════════

enum NexusProjectStatus {
  PENDING_PAYMENT
  PENDING_REVIEW
  APPROVED
  ACTIVE
  REJECTED
  EXHAUSTED
  PAUSED
}

enum NexusLaunchStatus {
  PENDING
  ACTIVE
  EXHAUSTED
  REFUNDED
  CANCELLED
}

enum NexusEventType {
  IMPRESSION
  CLICK
  DISMISS
}

enum NexusGuardianStatus {
  PENDING
  APPROVED
  MANUAL_REVIEW
  REJECTED
}

enum NexusBlacklistType {
  DOMAIN
  EMAIL
  ANONYMOUS_ID
}

enum NexusReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

model NexusProject {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String             @db.Text
  url             String
  imageUrl        String?
  category        String?
  tags            String[]           @default([])
  categoryVector  Float[]            @default([])
  audienceVector  Float[]            @default([])
  status          NexusProjectStatus @default(PENDING_PAYMENT)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  approvedAt      DateTime?
  launchedAt      DateTime?
  launches        NexusLaunch[]
  guardianReview  NexusGuardianReview?

  @@map("nexus_projects")
  @@index([userId])
  @@index([status])
}

model NexusLaunch {
  id              String            @id @default(cuid())
  projectId       String
  project         NexusProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  stripeSessionId String?           @unique
  stripePaymentId String?           @unique
  amountPaid      Float             @default(19.99)
  currency        String            @default("usd")
  status          NexusLaunchStatus @default(PENDING)
  impressions     Int               @default(0)
  clicks          Int               @default(0)
  reaches         Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  activatedAt     DateTime?
  expiresAt       DateTime?
  events          NexusEvent[]

  @@map("nexus_launches")
  @@index([projectId])
  @@index([userId])
  @@index([status])
}

model NexusEvent {
  id          String         @id @default(cuid())
  launchId    String
  launch      NexusLaunch    @relation(fields: [launchId], references: [id], onDelete: Cascade)
  projectId   String
  anonymousId String
  eventType   NexusEventType
  contextUrl  String?
  createdAt   DateTime       @default(now())

  @@map("nexus_events")
  @@index([launchId])
  @@index([projectId])
  @@index([anonymousId])
  @@index([createdAt])
}

model NexusGuardianReview {
  id             String              @id @default(cuid())
  projectId      String              @unique
  project        NexusProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fraudScore     Float               @default(0)
  spamScore      Float               @default(0)
  maliciousScore Float               @default(0)
  overallScore   Float               @default(0)
  status         NexusGuardianStatus @default(PENDING)
  flags          String[]            @default([])
  notes          String?
  reviewer       String              @default("auto")
  reviewedAt     DateTime?
  createdAt      DateTime            @default(now())

  @@map("nexus_guardian_reviews")
}

model NexusBlacklist {
  id        String             @id @default(cuid())
  type      NexusBlacklistType
  value     String             @unique
  reason    String?
  createdAt DateTime           @default(now())

  @@map("nexus_blacklist")
}

model OctoBlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String   @db.Text
  keyword         String?
  metaDescription String?
  excerpt         String?
  coverImage      String?
  category        String   @default("ai-automation")
  language        String   @default("en")
  author          String   @default("Octopus AI")
  status          String   @default("published")
  readTime        Int?     @default(10)
  wordCount       Int?     @default(0)
  seriesId        String?
  seriesPosition  Int?
  seriesTheme     String?
  views           Int      @default(0)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("octo_blog_posts")
  @@index([slug])
  @@index([category])
  @@index([language])
  @@index([status])
  @@index([publishedAt])
}

model NexusReport {
  id          String            @id @default(cuid())
  projectId   String
  anonymousId String
  reason      String
  status      NexusReportStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  @@map("nexus_reports")
  @@index([projectId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// TASK MANAGER — Gestión de tareas personales
// ═══════════════════════════════════════════════════════════════════════════════

model TaskItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("pending") // pending, in_progress, completed
  category    String?  @default("general")
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("task_items")
  @@index([userId])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([dueDate])
}
// ═══════════════════════════════════════════════════════════════════════════════
// BROWSER AUTOMATION — Control remoto de navegador via Bridge
// ═══════════════════════════════════════════════════════════════════════════════

model BrowserSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String   @default("New Session")
  status         String   @default("idle") // idle, running, paused, error, completed
  currentUrl     String?
  lastScreenshot String?  @db.Text
  metadata       Json?
  commands       BrowserCommand[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("browser_sessions")
  @@index([userId])
  @@index([userId, status])
}

model BrowserTemplate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  steps       Json     // Array of command objects with {{variable}} placeholders
  variables   Json?    // [{name, label, type, defaultValue}]
  category    String?  // social_media, scraping, testing, etc.
  lastUsed    DateTime?
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  scheduledTasks ScheduledBrowserTask[]

  @@map("browser_templates")
  @@index([userId])
}

model BrowserCommand {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId    String
  session      BrowserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type         String   // goto, click, type, screenshot, scroll, wait, extract, evaluate
  params       Json?
  status       String   @default("pending") // pending, sent, completed, failed
  result       Json?
  screenshotUrl String? @db.Text
  error        String?  @db.Text
  duration     Int?     // ms
  tabId        String?  // tab identifier for multi-tab sessions
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  @@map("browser_commands")
  @@index([sessionId, status])
  @@index([userId])
}

model ScheduledBrowserTask {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId   String
  template     BrowserTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name         String
  schedule     String   // cron expression or 'once'
  variables    Json?    // Variable values for the template
  status       String   @default("active") // active, paused, completed, failed
  lastRun      DateTime?
  nextRun      DateTime?
  runCount     Int      @default(0)
  lastResult   String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("scheduled_browser_tasks")
  @@index([userId])
  @@index([status, nextRun])
}
