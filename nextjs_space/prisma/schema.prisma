datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AgentLog {
  id        String   @id @default(cuid())
  projectId String
  agentName String
  agentType String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  serviceType String
  name        String
  apiKey      String
  baseUrl     String?
  status      String    @default("inactive")
  lastTested  DateTime?
  lastUsed    DateTime?
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceType])
  @@index([userId])
}

model ArmConnection {
  id          String    @id @default(cuid())
  userId      String
  armType     String
  name        String
  status      String    @default("connected")
  credentials String
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, armType])
}

model ArmData {
  id         String   @id @default(cuid())
  userId     String
  armType    String
  dataType   String
  title      String
  content    String
  metadata   String?
  externalId String?
  syncedAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, armType, externalId])
  @@index([armType])
  @@index([dataType])
  @@index([userId])
}

model ChatMessage {
  id              String           @id @default(cuid())
  sessionId       String
  role            String
  content         String
  metadata        String?
  createdAt       DateTime         @default(now())
  session     ChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  feedback MessageFeedback?
}

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  projectId   String?
  title       String        @default("Nueva conversación")
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages ChatMessage[]
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreativeAsset {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  prompt      String
  content     String
  thumbnail   String?
  platform    String?
  format      String?
  status      String   @default("ready")
  metadata    String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  User        User     @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([userId])
}

model GraphEntity {
  id                                                 String          @id @default(cuid())
  userId                                             String
  name                                               String
  entityType                                         String
  properties                                         String?
  mentions                                           Int             @default(1)
  firstSeen                                          DateTime        @default(now())
  lastSeen                                           DateTime        @default(now())
  createdAt                                          DateTime        @default(now())
  updatedAt                                          DateTime        @updatedAt
  objectRelations  GraphRelation[] @relation("GraphRelation_objectIdToGraphEntity")
  subjectRelations GraphRelation[] @relation("GraphRelation_subjectIdToGraphEntity")

  @@unique([userId, name, entityType])
  @@index([entityType])
  @@index([name])
  @@index([userId])
}

model GraphRelation {
  id                                               String      @id @default(cuid())
  userId                                           String
  subjectId                                        String
  predicate                                        String
  objectId                                         String
  weight                                           Float       @default(1.0)
  source                                           String?
  context                                          String?
  createdAt                                        DateTime    @default(now())
  updatedAt                                        DateTime    @updatedAt
  object  GraphEntity @relation("GraphRelation_objectIdToGraphEntity", fields: [objectId], references: [id], onDelete: Cascade)
  subject GraphEntity @relation("GraphRelation_subjectIdToGraphEntity", fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@index([predicate])
  @@index([subjectId])
  @@index([userId])
}

model GrowthAction {
  id          String      @id @default(cuid())
  userId      String
  leadId      String?
  actionType  String
  title       String
  description String?
  payload     String?
  reasoning   String?
  status      String      @default("pending")
  executedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lead  GrowthLead? @relation(fields: [leadId], references: [id])
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([actionType])
  @@index([createdAt])
  @@index([leadId])
  @@index([status])
  @@index([userId])
}

model GrowthInsight {
  id          String   @id @default(cuid())
  userId      String
  insightType String
  title       String
  description String
  data        String?
  score       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([insightType])
  @@index([userId])
}

model GrowthLead {
  id                  String          @id @default(cuid())
  userId              String
  businessName        String
  businessType        String?
  contactName         String?
  email               String?
  emailCategory       String?
  phone               String?
  website             String?
  city                String?
  state               String?
  country             String?         @default("US")
  googleRating        Float?
  status              String          @default("new")
  priority            String          @default("medium")
  qualificationScore  Int             @default(0)
  leadTier            String          @default("diamond")
  leadSource          String?
  painPoints          String?
  notes               String?
  tags                String?                        // JSON array of tags e.g. ["blog-lead","wildverse"]
  sourceUrl           String?                        // URL that originated the lead (e.g. blog article)
  followUpCount       Int             @default(0)
  lastContactedAt     DateTime?
  lastFollowUpAt      DateTime?
  emailBounced        Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  lastReplyAt         DateTime?
  replyClassification String?
  actions        GrowthAction[]
  User                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       GrowthMessage[]
  campaignLeads  CampaignLead[]

  @@index([city])
  @@index([emailCategory])
  @@index([leadTier])
  @@index([qualificationScore])
  @@index([status])
  @@index([userId])
}

model GrowthMessage {
  id          String     @id @default(cuid())
  userId      String
  leadId      String
  direction   String
  channel     String     @default("email")
  subject     String?
  content     String
  metadata    String?
  trackingId  String?    @unique
  openedAt    DateTime?
  openCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  lead GrowthLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  User       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([direction])
  @@index([leadId])
  @@index([userId])
  @@index([trackingId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CAMPAIGN SYSTEM - Campañas reales de Growth Engine
// ═══════════════════════════════════════════════════════════════════════════════

model Campaign {
  id              String          @id @default(cuid())
  userId          String
  name            String
  description     String?         @db.Text
  campaignType    String          @default("outreach")  // outreach, seasonal, nurture, reactivation, custom
  status          String          @default("draft")      // draft, active, paused, completed, archived
  targetCriteria  String?         @db.Text               // JSON: { businessType, city, leadTier, minScore }
  emailSubject    String?
  emailTemplate   String?         @db.Text
  sequence        String?         @db.Text               // JSON array of email steps for multi-touch
  totalLeads      Int             @default(0)
  sentCount       Int             @default(0)
  openCount       Int             @default(0)
  replyCount      Int             @default(0)
  convertedCount  Int             @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads           CampaignLead[]

  @@index([userId])
  @@index([status])
  @@index([campaignType])
  @@index([createdAt])
}

model CampaignLead {
  id          String      @id @default(cuid())
  campaignId  String
  leadId      String
  status      String      @default("pending")  // pending, sent, opened, replied, converted, bounced
  currentStep Int         @default(0)            // which step of the drip sequence (0 = not started)
  lastStepAt  DateTime?                          // when the last step was sent
  sentAt      DateTime?
  openedAt    DateTime?
  repliedAt   DateTime?
  createdAt   DateTime    @default(now())
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead        GrowthLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MEGA SKILL: LEAD-TO-ASSET — Motor de ejecución principal
// ═══════════════════════════════════════════════════════════════════════════════

model LeadAssetProcess {
  id              String    @id @default(cuid())
  userId          String
  leadId          String?
  leadName        String
  leadEmail       String?
  leadCompany     String?
  leadMetadata    String?                          // JSON: campos custom del lead
  assetType       String    @default("video")      // video, image, audio, document
  assetUrl        String?                          // URL del asset generado
  assetId         String?                          // ref a CreativeAsset si se guarda
  status          String    @default("pending")    // pending, creating_lead, generating_asset, sending_email, completed, error
  stage           String    @default("queued")     // sub-estado descriptivo
  progress        Int       @default(0)            // 0-100
  sendEmail       Boolean   @default(false)
  emailSent       Boolean   @default(false)
  emailTemplateId String?
  language        String    @default("es")
  projectName     String?
  errorMessage    String?
  metadata        String?                          // JSON: utm, template, config extra
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  User            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([leadId])
  @@index([createdAt])
}

model KnowledgeChunk {
