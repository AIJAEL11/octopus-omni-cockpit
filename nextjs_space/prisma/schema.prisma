// ═══════════════════════════════════════════════════════════════════════════════
// CUSTOM AGENTS (Agent Factory) - Per-user isolated agents
// ═══════════════════════════════════════════════════════════════════════════════

model CustomAgent {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  description       String?  @db.Text
  model             String   @default("gpt-4.1")
  category          String   @default("custom")
  systemPrompt      String   @db.Text
  isActive          Boolean  @default(true)
  icon              String?  @default("🤖")
  temperature       Float    @default(0.7)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CUSTOM SKILLS (Skill Factory) - Per-user isolated skills
// ═══════════════════════════════════════════════════════════════════════════════

model CustomSkill {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  description       String?  @db.Text
  category          String   @default("custom")
  code              String?  @db.Text
  usageCount        Int      @default(0)
  isActive          Boolean  @default(true)
  createdBy         String?  @default("jarvis")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CUSTOM MCP SERVERS (MCP Factory) - Per-user isolated MCP connections
// ═══════════════════════════════════════════════════════════════════════════════

model CustomMcp {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  description       String?  @db.Text
  category          String   @default("custom")
  icon              String?  @default("Plug")
  color             String?  @default("#6366F1")
  endpoint          String?  @db.Text
  apiKey            String?  @db.Text
  isConnected       Boolean  @default(false)
  capabilities      String[] @default([])
  version           String?  @default("1.0.0")
  lastSync          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MULTI-WORKSPACE SYSTEM - Para agencias y múltiples marcas
// ═══════════════════════════════════════════════════════════════════════════════

model Workspace {
  id                String    @id @default(cuid())
  userId            String
  name              String
  slug              String?
  logo              String?
  description       String?
  
  // Branding
  primaryColor      String    @default("#FFD700")
  secondaryColor    String    @default("#1a1a2e")
  accentColor       String?
  brandVoice        String?   @db.Text  // Tono de voz para contenido
  
  // LinkedIn OAuth (por workspace)
  linkedinAccessToken   String?   @db.Text
  linkedinRefreshToken  String?   @db.Text
  linkedinTokenExpiry   DateTime?
  linkedinUserId        String?
  linkedinUsername      String?
  linkedinProfileUrl    String?
  linkedinProfileImage  String?
  
  // Twitter OAuth (futuro)
  twitterAccessToken    String?   @db.Text
  twitterRefreshToken   String?   @db.Text
  twitterTokenExpiry    DateTime?
  twitterUserId         String?
  twitterUsername       String?
  
  // Instagram (futuro)
  instagramAccessToken  String?   @db.Text
  instagramUserId       String?
  instagramUsername     String?
  
  // UGC Config
  defaultAvatarId       String?
  defaultVoiceId        String?
  
  // Metadata
  isDefault         Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialConnections SocialConnection[]
  socialPosts       SocialPost[]
  
  @@unique([userId, slug])
  @@index([userId])
}

model Subscription {
